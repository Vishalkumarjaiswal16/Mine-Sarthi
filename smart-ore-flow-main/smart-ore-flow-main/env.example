# ============================================
# Hardware Integration Configuration
# ============================================
# Copy this file to .env and fill in your values

# WebSocket Configuration (Primary - Bidirectional)
# Use WebSocket for real-time bidirectional communication
VITE_WS_URL=ws://localhost:3001
# Example: ws://your-server.com:3001
# Example with SSL: wss://your-server.com:3001

# Server-Sent Events Configuration (Alternative - One-way)
# Use SSE if WebSocket is not available
VITE_SSE_URL=http://localhost:3001/events
# Example: http://your-server.com:3001/events
# Example with SSL: https://your-server.com:3001/events

# ============================================
# MQTT Configuration (Optional)
# ============================================
# Use MQTT if you prefer MQTT protocol for IoT devices

VITE_MQTT_BROKER_URL=your-mqtt-broker.com
# Example: mqtt.example.com

VITE_MQTT_PORT=8083
# Standard ports: 1883 (non-SSL), 8883 (SSL), 8083 (WebSocket), 8884 (WebSocket SSL)

VITE_MQTT_USERNAME=your-username
VITE_MQTT_PASSWORD=your-password
VITE_MQTT_CLIENT_ID=smart-ore-flow-client
VITE_MQTT_USE_SSL=false
# Set to true for secure MQTT connections

# ============================================
# Data Source Configuration
# ============================================

# Set to false when using real hardware data
# Set to true for development/testing with mock data
VITE_USE_MOCK_DATA=true

# ============================================
# Quick Start Guide
# ============================================
# 1. Copy this file: cp env.example .env
# 2. Set VITE_WS_URL or VITE_SSE_URL to your backend server
# 3. Set VITE_USE_MOCK_DATA=false when ready for real hardware
# 4. Restart your development server: npm run dev
# 5. Check Digital Twin page for "Real-time Connected" badge

# ============================================
# Expected Data Format
# ============================================
# Your backend should send data in this format:
#
# {
#   "timestamp": "2024-01-01T12:00:00.000Z",
#   "deviceId": "equipment-1",
#   "type": "equipment",
#   "data": {
#     "status": "active",
#     "load": 85,
#     "temperature": 45.5,
#     "vibration": 2.5,
#     "alerts": 0,
#     "name": "Hopper"
#   }
# }
#
# Device IDs should extract step numbers:
# - "equipment-1" → Step 1 (Hopper)
# - "equipment-2" → Step 2 (Vibrating Feeder)
# - etc.

