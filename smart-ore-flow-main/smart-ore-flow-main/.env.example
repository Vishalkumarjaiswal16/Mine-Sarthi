# MQTT Configuration
# Set VITE_USE_MOCK_DATA=false to use real MQTT data
VITE_USE_MOCK_DATA=true

# MQTT Broker Configuration
VITE_MQTT_BROKER_URL=localhost
VITE_MQTT_PORT=8083
VITE_MQTT_USERNAME=
VITE_MQTT_PASSWORD=
VITE_MQTT_CLIENT_ID=smart-ore-flow-client
VITE_MQTT_USE_SSL=false

# For production with SSL:
# VITE_MQTT_BROKER_URL=your-broker.example.com
# VITE_MQTT_PORT=8884
# VITE_MQTT_USE_SSL=true
# VITE_MQTT_USERNAME=your-username
# VITE_MQTT_PASSWORD=your-password

