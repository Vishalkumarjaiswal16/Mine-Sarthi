# Environment Configuration for Data Pipeline
# Load this file using python-dotenv

# InfluxDB Configuration
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=mine_sarthi
INFLUXDB_BUCKET=crusher_metrics
INFLUXDB_TOKEN=test-token

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mine_sarthi
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# MQTT Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=mining/crusher_01/metrics

# Legacy InfluxDB Configuration (for compatibility with existing code)
INFLUX_HOST=localhost
INFLUX_PORT=8086
INFLUX_DB=mine_sarthi_realtime

# Legacy PostgreSQL Configuration (for compatibility with existing code)
PG_HOST=localhost
PG_PORT=5432
PG_DB=sensor_archive
PG_USER=sensor
PG_PASSWORD=sensorpass

# MQTT Bridge Configuration
MQTT_HOST=localhost
MQTT_TOPIC_PATTERN=mining/+/metrics
BACKEND_URL=http://localhost:8000/ingest
